#IMPORTS 

import sys           
import datetime     
import hashlib       
import os            

#AUDIT - Rashed 

def log_event(message):
    with open("audit_log.txt", "a") as log:
        timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        log.write(f"[{timestamp}] {message}\n")

#HASHING - Rashed

HASH_FILE = "save_hash.txt"   # Stores SHA-256 
SAVE_FILE = "save_file.txt"   

def compute_hash(filepath):
    sha256 = hashlib.sha256()
    with open(filepath, "rb") as f:
        # Read the file in 4096-byte chunks to handle large files efficiently
        for chunk in iter(lambda: f.read(4096), b""):
            sha256.update(chunk)
    return sha256.hexdigest()

def save_hash(hash_value):
    with open(HASH_FILE, "w") as f:
        f.write(hash_value)

def load_hash():
    if not os.path.exists(HASH_FILE):
        return None
    with open(HASH_FILE, "r") as f:
        return f.read().strip()

def verify_save_integrity():
    if not os.path.exists(SAVE_FILE):
        print("No save file found.")
        return False

    stored = load_hash()
    if stored is None:
        print("No hash record found – cannot verify integrity.")
        return False

    current = compute_hash(SAVE_FILE)

    if current == stored:
        print("[Tamper Check PASSED] Save file is intact.")
        log_event("Tamper check passed – save file loaded successfully.")
        return True
    else:
        print(f"  Expected : {stored}")
        print(f"  Got      : {current}")
        log_event("Tamper check FAILED – save file may have been tampered with.")
        return False

#Hajra: start

class Game:
    def __init__(self, username):
        self.username = username
        self.inventory = []
        self.story_arc = 1  
        self.health = 100
        self.game_active = True

    def add_item(self, item):
        self.inventory.append(item)
        print(f"[{item} Added Successfully]")
#LOAD
    def load_game(self):
        if not verify_save_integrity():
            print("Load aborted to protect game state.")
            return

        try:
            with open(SAVE_FILE, "r") as file:
                self.story_arc = int(file.readline().strip())
                self.health = int(file.readline().strip())
                inventory_line = file.readline().strip()
                # If inventory line is empty, default to an empty list
                self.inventory = inventory_line.split(",") if inventory_line else []

            print("Game loaded!")
            print(f"  Arc: {self.story_arc}  |  Health: {self.health}  |  Inventory: {self.inventory}")
            log_event(f"Game loaded by {self.username}")

        except FileNotFoundError:
            print("No save file found.")

#Save Game
    def save_game(self):
        with open(SAVE_FILE, "w") as file:
            file.write(str(self.story_arc) + "\n")
            file.write(str(self.health) + "\n")
            # Inventory is stored as a comma-separated string
            file.write(",".join(self.inventory) + "\n")

        # Hash the file immediately after writing to capture its clean state
        file_hash = compute_hash(SAVE_FILE)
        save_hash(file_hash)
        print("Game saved!")
        print(f"  SHA-256 fingerprint: {file_hash}")
        log_event(f"Game saved – {self.username} at arc {self.story_arc} | hash={file_hash}")

    # STATS 
    def show_stats(self):
        """
        Displays the player's current story arc, health, and inventory.
        Pauses until the player presses Enter before returning to the game.
        """
        print("\n--- STATS ---")
        print("Story Arc:", self.story_arc)
        print("Health:", self.health)
        print("Inventory:", self.inventory)
        input("\nPress Enter to continue...")

    # MENU 
    def get_menu_choice(self, limit):
        while True:
            choice = input("Enter choice (press m to see menu): ")
            if choice == "m":
                # Show the in-game side menu
                while True:
                    print("\n--- MAIN MENU ---")
                    print("A. Continue Playing")
                    print("B. Save Game")
                    print("C. Load Game")
                    print("D. Show Stats")
                    print("E. Quit Game")

                    menu_choice = input("Choose an option: ")

                    if menu_choice.lower() == "a":
                        break  # Return to the game
                    elif menu_choice.lower() == "b":
                        self.save_game()
                        input("Press Enter to continue...")
                    elif menu_choice.lower() == "c":
                        self.load_game()
                        input("Press Enter to continue...")
                    elif menu_choice.lower() == "d":
                        self.show_stats()
                    elif menu_choice.lower() == "e":
                        print("Goodbye.")
                        sys.exit()
                    else:
                        print("Invalid choice.")
            else:
                try:
                    num = int(choice)
                    if num < 1 or num > limit:
                        print("Invalid choice.")
                    else:
                        return num
                except ValueError:
                    print("Invalid choice.")
                    log_event("Invalid input entered by player.")


    def start (self):
        print("\n--- HOW TO PLAY ---")
        print("Enter the number of your chosen action when prompted.")
        print("Press 'm' at any choice to open the main menu.")
        print("You can save, load, and check your stats from the menu.")
        print("Your choices affect the story and ending.")
        print("-------------------\n")
        print(f"\nWelcome {self.username} to the World of the Forgotten.")
        print("You were not supposed to wake up.")
        print("\nYou wake on cold grass. The sky above you swirls like paint.")
        print("\nA voice echoes:")
        print("'You're late again!'\n")
        self.opening_choice()


    def opening_choice(self):
        print("Three paths stretch before you.\n")
        print("1. Follow the white figureFirst Life")
        print("2. Walk into the forest alone 'Deja Vu'")
        print("3. Follow the whispering voiceReincarnation/ Revenge")


        while True:
            choice = input("\nWhich path do you choose? (Enter 1,2, or 3): ")
            if choice == "1":
                self.path_one()
                break
            elif choice == "2":
                self.path_two()
                break
            elif choice == "3":
                self.path_three()
                break
            else:
                print("You made an invalid choice. Please enter a valid number between 1 and 3.")

    def path_one(self):
#Major event 1, NPC 1, Drop 1
        self.story_arc += 1
        log_event(f"{self.username} entered Path 1: First Life")
        print('\nScene 1: The Garden\n\nYou wake in a surreal garden. The sky swirls above you.\nYou see something on the ground.\n')
        print('1. Pick up the object\n2. Ignore it\n')
        choice = self.get_menu_choice(2)
        if choice == 1:
            # Picking up the watch provides a safety net at the Gatekeeper riddle 
            self.inventory.append("Cracked Watch") #Cracked watch can be used to redo loop and avoid loop ending in major event 4
            print("You obtained: Cracked Watch\n")
        else:
            print("\nYou leave it behind...")
#Major event 2, NPC 2, Drop 2
        self.story_arc += 1
        print('\nScene 2: Tea Party\n\nYou walk further into the garden and encounter a tea party.\nA long table stretches endlessly. The Host smiles.\n"You made it. You always do"\nThe Host offers you a cup of tea.\n')
        print("1. Drink the tea\n2. Refuse\n")
        choice = self.get_menu_choice(2)

        if choice == 1: # Tea Vial can be used to bypass the Gatekeeper riddle later in major event 4
            print('You drink the tea.\nYou obtained: "Tea Vial"\nThe world bends slightly. Something feels... off...\nThe Host waves goodbye and walks away\n')
            self.inventory.append("Tea Vial")
        else: # Refusing has no item reward but the Host disappears
            print('You refuse the tea. The Hosts smile fades.\n"How disappointing."\nThe Host disappears right before your eyes\n')

#Major event 3, Drop 3, Challenge 1, 
        self.story_arc += 1
        print("\nScene 3: Mirror Garden\n\nYou walk into a garden filled with mirrors, but your reflection moves unusually\n")
        print("1. Touch the mirror\n2. Look away\n")
        choice = self.get_menu_choice(2)

        if choice == 1: # Touching the mirror gives an item but deals damage now AND in future scenes
            self.health -= 20
            self.inventory.append("Glass Shard")
            print('\nThe mirror cracks at your slight touch; your reflection smiles back incorrectly.\nYou obtained: "Glass Shard"\nYou start to bleed.\nYou have lost 20 health and will continue to lose health\n')
        else:
            print("\nYou avoid your own reflection\n")

#Major event 4, NPC 3, Drop 4, Challange 2
        self.story_arc += 1
        print('\nScene 4: Gatekeeper\n\nYou feel disoriented and find yourself in a room.\nThe only exit is blocked by a tall figure.\n"Answer correctly... Or remain!"\n')

        if "Glass Shard" in self.inventory:         # Challange 2: Glass Shard drain health each scene it's carried
            self.health -= 20
            print("You have lost 20 health\n")

        # Loop until the player answers correctly, bypasses with Tea Vial, or accepts their fate
        repeat = 1
        while repeat == 1:
            print('Riddle: "What has keys but cannot open locks?"\n')

            if "Tea Vial" in self.inventory: #If tea vial able to skip loop
                print("1. Use Tea Vial")

            answer = input("Input your answer: ").lower() #No tea vial have to answer correcrtly 

            if answer == "1" and "Tea Vial" in self.inventory: # Tea Vial to skip the riddle
                print("\nThe Gatekeeper takes the Tea Vial and frowns. \nHe steps aside and lets you through.\n")
                self.inventory.remove("Tea Vial")
                repeat += 1  # Exit loop

            elif answer == "piano": #Correct riddle
                print('The Gatekeeper frowns but lets you through anyway.\nYou obtained: "Shiny Key"\n')
                self.inventory.append("Shiny Key")
                repeat += 1  # Exit the loop

            else: # Wrong answer — able to retry with Cracked Watch. 
                print('The Gatekeeper smiles. "WRONG"\n')

                if "Cracked Watch" in self.inventory:
                    print("1. Accept your fate\n2. Use Cracked Watch\n")
                    choice = self.get_menu_choice(2) #Loop
                else:
                    print("1. Accept your fate")
                    choice = self.get_menu_choice(1)

                if choice == 1:
                    # Bad Ending: player gives up
                    print("\nBad Ending: Loop\nYou are trapped forever.\n")
                    log_event(f"{self.username} Bad Ending: Loop")
                    sys.exit()
                else:
                    # Cracked Watch gives one more attempt
                    print("\nYou only get one more chance. Use it wisely.\n")
#Major event 5, NPC 3 AND 4, Drop 5
        self.story_arc += 1
        print('\nScene 5: Misty Meadow\n\nAs you wander through a misty meadow, a girl with a wide, toothy grin appears.\n"Would you be a dear and watch Pompom for me? I will not be long!"\n')

        # Glass Shard drain health
        if "Glass Shard" in self.inventory:
            self.health -= 20
            print("You have lost 20 health\n")

        print("1. Yes\n2. No\n")
        choice = self.get_menu_choice(2)

        # Will be used in final sence
        self.helpcat = False

        if choice == 1:
            # Agree to watch the cat
            print("\nThank you, will be back soon!\nShe skedaddles away.\nYou look down at a big fat purple cat.\n")
            print("1. Pet the cat\n2. Hit the cat\n")
            choice = self.get_menu_choice(2)

            if choice == 1:
                # Cat will not steal item later in final sence
                self.helpcat = True
                print('\nYou reach toward the cat carefully.\nThe Cheshire Cat suddenly turns to glare at you. "No." Then disappears.\n\nThe smiling girl appears. "Thank you! Here!"\nShe gives you bandages. You obtained: "Bandages"')
                print("Do you want to use the bandages?\n")
                print("1. Yes\n2. No\n")
                choice = self.get_menu_choice(2)

                if choice == 1:
                    # Use bandages to restore health
                    print("\nHealth restored to 100\n")
                    self.health = 100
                else:
                    # Save bandages in inventory for the Door scene item count
                    print('\nYou decline. You obtained: "Bandages"\n')
                    self.inventory.append("Bandages")
            else:
                # Hitting the cat deals heavy damage - death
                print("\nYou hit the cat. Cheshire bites you. You lose 50 health\n")
                self.health -= 50

                if self.health <= 0:
                    print("\nBad Ending: Death\nDo not hit the cat.\n")
                    log_event(f"{self.username} reached Bad Ending: Death")
                    sys.exit()
        else:
            # Refusing to help means no Cheshire Cat protection at the Door
            print('\nShe frowns. "You will regret this."\nThe cat lunges at you\nYou lose 20 health\nWhen you regain your vison, they are gone')
            self.health -= 20

#Final, NPC 5
        self.story_arc += 1
        print('Final: The Door\n\nYou see pillars in front of a glowing door.\n The highest pillar reads: "Place three items to open the door"\n')

        # Final Glass Shard drain (if not protected by helpcat)
        if "Glass Shard" in self.inventory and self.helpcat == False:
            self.health -= 20
            print("You have lost 20 health\n")
            if self.health <= 0:
                print("\nBad Ending: Death\n So so unlucky\n")
                log_event(f"{self.username} reached Bad Ending: Death, so so unlucky")
                sys.exit()

        # If player didn't help the cat, Cheshire steals an item as punishment
        if self.helpcat == False:
            if self.inventory:
                stolen = self.inventory[0]
                print("As you rummage through your inventory, a purple object hits you square in the face.")
                print(f"You have lost 10 health. Your {stolen} is gone.\n")
                self.health -= 10
                self.inventory.remove(stolen)
            input("Press Enter to continue...")

        # Place each item on a pillar
        for item in self.inventory:
            print(f"\nYou place {item} on a pillar\n")
            input("Press Enter to continue...")

        # Freedom Ending requires at least 3 items on the pillars
        if len(self.inventory) >= 3:
            print("\nFreedom Ending: You step through the door.\nThe sun blinds you, but you are free.\n")
            log_event(f"{self.username} reached Freedom Ending")
            sys.exit()
        else:
            # Not enough items
            print("\nAcceptance Ending: The door does not open.\nYou come to terms with the fact that you will never leave.\n")
            log_event(f"{self.username} reached Acceptance Ending")
            sys.exit()

###
#This is the second path. There are going to be three scenes.
    def path_two(self):       
        self.story_arc += 1
        log_event(f"{self.username} entered Path 2: Deja Vu")
        print("\nPath 2: Deja Vu")
        print("Mirror Hall >> Maze >> Clock Tower\n")
        self.Mirror_hall_scene()

    #This is the first scene
    def Mirror_hall_scene(self):
        try:
            print("Scene 1: Hall of Mirrors")
            print("You've entered a hall of mirrors!")
            print("One reflection does not follow you.")
            print("You chose differently last time.\n")
            print("1. Touch the mirror")
            print("2. Ignore it\n")
            choice = self.get_menu_choice(2)

            if choice == 1:
                # Memory Fragment unlocks an easier path through the maze
                print("A memory flashes through your mind.")
                self.add_item("Memory Fragment")
                log_event("Path 2: Player touched the mirror, Memory Fragment collected.")
            else:
                print("You walk past. The reflection watches silently.")

            self.maze_scene()
        except Exception as e:
            print("Error in Mirror Hall:", e)
            self.maze_scene()  # Continue even if something goes wrong

    #This is the second scene.
    def maze_scene(self):
        try:
            print("\nScene 2: Maze")
            print("The paths repeat. You feel stuck.\n")

            if "Memory Fragment" in self.inventory:
                # Player has the fragment so offer a smarter option
                print("1. Follow instinct")
                print("2. Use Memory\n")
                choice = self.get_menu_choice(2)

                if choice == 2:
                    # Using the fragment = fast escape, noted in the ending
                    print("Memory guides you perfectly!")
                    print("You escape the maze.\n")
                    log_event("Path 2: Player used Memory Fragment to escape the maze.")
                    self.clock_tower_scene(True)
                else:
                    # Ignored the fragment, still escapes, just slower
                    print("You wander longer but eventually escape.\n")
                    self.clock_tower_scene(False)
            else:
                # No fragment, only one option
                print("1. Follow instinct\n")
                self.get_menu_choice(1)
                print("You wander longer but eventually escape.\n")
                self.clock_tower_scene(False)
        except Exception as e:
            print("Error in Maze:", e)
            self.clock_tower_scene(False)

    #this is the third scene.
    def clock_tower_scene(self, fast_escape):
        try:
            print("Scene 3: Clock Tower")
            print("A massive clock ticks loudly.\n")
            print("1. Reset the clock")
            print("2. Break the clock\n")
            choice = self.get_menu_choice(2)

            if choice == 1:
                self.ending_2()
            else:
                self.ending_3(fast_escape)
        except Exception as e:
            print("Error in Clock Tower:", e)
            self.ending_3(False)

    #This is a possible ending
    def ending_2(self):
        #Using the try and except block to avoid any errors.
        try:
            print("\nEnding 2: Partial Freedom")
            print("Time resets. The world shifts.")
            print("You fall into darkness.")
            print("Bittersweet escape achieved.\n")
            log_event("Path 2: Player reached Ending 2: Partial Freedom.")
            self.game_active = False
        except Exception as e:
            print("Ending 2: Partial freedom achieved.", e)
            self.game_active = False

    #This is another possible ending
    def ending_3(self, fast_escape):
        #Using the try and except block to avoid any errors
        try:
            print("\nEnding 3: Aware Loop")
            print("The clock shatters.")
            if fast_escape:
                # Bonus acknowledgement for smart item use
                print("You used the Memory Fragment perfectly.")
            print("You remain – but now you remember everything.")
            print("Full awareness achieved.\n")
            log_event("Path 2: Player reached Ending 3: Aware Loop.")
            self.game_active = False
        except Exception as e:
            print("Ending 3: Aware loop achieved.", e)
            self.game_active = False

    def path_three(self):
        self.story_arc += 1
        log_event(f"{self.username} entered Path 3: Reincarnation")

        # Scene 1
        print("\nScene 1: Hidden Tunnel\n")
        print("You already know this place.")
        print("The whispering voice guides you underground.")
        print('"Finally... you remember."\n')
        print("1. Enter the tunnel")
        print("2. Turn back\n")
        choice = self.get_menu_choice(2)

        if choice == 1:
            print("\nYou step into the darkness.")
            print("Fragments of your past flash before your eyes.\n")
        else:
            print("\nYou try to turn back...")
            print("But the garden shifts around you.")
            print("There is no escape. You are pulled forward.\n")

        self.inventory.append("Memory Fragment")
        print('You obtained: "Memory Fragment"\n')

        # Scene 2
        self.story_arc += 1
        print("\nScene 2: The Forgotten Ones\n")
        print("Figures emerge from the shadows.")
        print("The people who wronged you in your past life stare silently.\n")
        print('"Do you still hate us?"\n')
        print("1. Forgive them")
        print("2. Take revenge\n")

        self.revenge = False
        choice = self.get_menu_choice(2)

        if choice == 1:
            print('\nYou lower your weapon.')
            print('"I will end the cycle differently."\n')
            self.inventory.append("Mask Fragment")
            print('You obtained: "Mask Fragment"\n')
            log_event(f"{self.username} chose forgiveness in Scene 2")
        else:
            self.revenge = True
            print("\nYour anger consumes you.")
            print("The world around you darkens.\n")
            self.inventory.append("Shadow Crown")
            print('You obtained: "Shadow Crown"\n')
            log_event(f"{self.username} chose revenge in Scene 2")

        # Scene 3
        self.story_arc += 1
        print("\nScene 3: Memory Chamber\n")
        print("A massive door blocks your path.")
        print('Words appear across its surface:\n')
        print('"What breaks the cycle?"\n')
        print("(Hint: speak your truth)\n")

        repeat = 1
        while repeat == 1:
            answer = input("Choose Story Arc: ").lower()

            if answer == "forgiveness":
                print("\nThe door slowly opens.\n")
                repeat += 1
            elif answer == "revenge":
                if self.revenge:
                    print("\nThe darkness accepts your answer.")
                    print("The door opens violently.\n")
                    repeat += 1
                else:
                    print("\nThe chamber rejects your answer.")
                    print("Your path does not match your words.\n")
            else:
                print("\nThe chamber remains silent.\n")
                print("1. Try again")
                print("2. Give up\n")
                choice = self.get_menu_choice(2)

                if choice == 2:
                    print("\nBad Ending: Forgotten\n")
                    print("Your memories fade forever.\n")
                    log_event(f"{self.username} reached Bad Ending: Forgotten")
                    sys.exit()

        # Final Scene
        self.story_arc += 1
        print("\nFinal Scene: Throne Room\n")
        print('The Host sits upon a throne of roots and glass.\n')
        print('"So... this is the version of you that remembers."\n')

        if "Mask Fragment" in self.inventory:
            print("The Host looks uneasy at the fragment in your hand.\n")
        if "Shadow Crown" in self.inventory:
            print("The throne trembles in response to your anger.\n")
        if "Memory Fragment" in self.inventory:
            print("The Host's eyes flicker. \"You remember all of it, don't you.\"\n")

        print("1. Destroy the system")
        print("2. Take control")
        print("3. Let go\n")
        choice = self.get_menu_choice(3)

        if choice == 1:
            print("\nTrue Ending: Freedom\n")
            print("The garden begins to collapse.")
            print("The sky finally clears.\n")
            print("You wake up somewhere real.")
            print("For the first time... you are free.\n")
            log_event(f"{self.username} reached True Ending: Freedom")
            sys.exit()

        elif choice == 2:
            print("\nDark Ending: The New Ruler\n")
            print("You sit upon the throne.")
            print("The garden bends to your will.\n")
            if self.revenge:
                print("You already know what comes next.")
                print("You became exactly what trapped you.\n")
            else:
                print("Maybe this time things will be different.")
                print("Maybe.\n")
            print('"They are late again."\n')
            log_event(f"{self.username} reached Dark Ending: New Ruler")
            sys.exit()

        else:
            print("\nCorruption Ending\n")
            print("You let everything go.\n")
            print("But something else takes your place.")
            print("Something worse.\n")
            print("The cycle continues.\n")
            log_event(f"{self.username} reached Corruption Ending")
            sys.exit()


def main():
    while True:
        username = input("Hello stranger. Enter a username: ")
        if len(username) >= 3:
            break
        else:
            print("Username must be at least 3 characters long. Try again!\n")


    game =Game(username)
    log_event(f"GAME_START - Player started a new game - User = {username}")
    game.start()


if __name__ == "__main__":
    main()

