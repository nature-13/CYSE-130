# defining the path_two function for the second path of the game
def path_two(self):
    self.story_arc += 1
    log_event(f"{self.username} entered path 2: Deja Vu")
    print(" Path 2: Deja Vu")
    print("Mirror Hall >> Mae >> Clock Tower")
    self.Mirror_hall_scene()

# This is the third scene.
def clock_tower_scene(self, fast_escape):
    try:
        print("Scene 3: Clock Tower")
        print("A massive clock ticks loudly")
        print("Choice:")
        print("1. Reset the clock")
        print("2. Break the clock")
        choice = self.get_menu_choice(2)
        # asking player for choice
        if choice == "1":
            self.ending_2()
        else:
            self.ending_3(fast_escape)
    except:
        print("Error")
        self.ending_3(False)

# this is the second scene.
def maze_scene(self):
    # using the try and except block to avoid errors.
    try:
        print("Scene 2: Maze")
        print("The paths repeat. You feel stuck")
        print("Choice:")
        # condition if the memory fragment is in the inventory
        if "Memory Fragment" in self.inventory:
            print("1. Follow instinct")
            print("2. Use Memory")
            choice = self.get_menu_choice(2)
            # asking player for their choice
            if choice == "2":
                print("Memory guides you perfectly!")
                print("You escape the maze.")
                log_event("Path 2: Player used Memory Fragment to escape the maze.")
                self.clock_tower_scene(True)
            else:
                print("You wander longer but eventually escape.")
                self.clock_tower_scene(False)
        else:
            print("1. Follow instinct")
            self.get_menu_choice(1)
            print("You wander longer but eventually escape")
            clock_tower_scene(False)
    except:
        print("Error")
        clock_tower_scene(False)

