def main():
    """
    Entry point for the game.
    Prompts the player for a username (minimum 3 characters),
    creates a Game instance, logs the session start, and begins the game.
    """
    while True:
        username = input("Hello stranger. Enter a username: ")
        if len(username) >= 3:
            break
        else:
            print("Username must be at least 3 characters long. Try again!\n")
 
    game = Game(username)
    log_event(f"Game started by user: {username}")
    game.start()
 
 
# Only run main() if this script is executed directly (not imported as a module)
if __name__ == "__main__":
    main()
